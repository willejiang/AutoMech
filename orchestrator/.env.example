# VLM / gateway creds — reuses the evaluator's AZURE_* names so one .env works
# for both halves. Copy to .env and fill in. .env is gitignored.
AZURE_OPENAI_ENDPOINT=https://hackathondefault.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=__PUT_KEY_HERE__
AZURE_VLM_DEPLOYMENT=gpt-5.4

# Optional: override the model cadam_bridge uses for .scad generation
# (defaults to AZURE_VLM_DEPLOYMENT).
# CADAM_MODEL=gpt-5.4

# How the loop drives cadam. "direct" = replicate generation via the LLM with
# cadam's own prompt (default, no Supabase). "http" = POST cadam's running
# server (NOT wired — needs Supabase auth + DB).
WORKER_MODE=direct

# Native OpenSCAD CLI for render_views.py (auto-detected if on PATH).
# OPENSCAD_BIN=/usr/bin/openscad
# BOSL2/MCAD library path (unzip worker/public/libraries/*.zip here).
OPENSCADPATH=/tmp/oscad-libs
