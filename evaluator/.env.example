# LLM endpoint for scenario_designer.py / strategy_selector.py / analyze.py.
# OpenAI-compatible. Two options:
#
# (A) Local GitHub Copilot API proxy (recommended for dev) — claude-opus-4.8:
# AZURE_OPENAI_ENDPOINT=http://localhost:8313/v1
# AZURE_OPENAI_API_KEY=not-needed-for-local-proxy
# AZURE_VLM_DEPLOYMENT=claude-opus-4.8
#
# (B) Azure OpenAI:
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/openai/v1
# AZURE_OPENAI_API_KEY=__PUT_KEY_HERE__
# AZURE_VLM_DEPLOYMENT=gpt-5.4
#
# Copy to .env (gitignored) and fill in. NEVER commit the real key.
AZURE_OPENAI_ENDPOINT=http://localhost:8313/v1
AZURE_OPENAI_API_KEY=not-needed-for-local-proxy
AZURE_VLM_DEPLOYMENT=claude-opus-4.8
